import Bottleneck from "bottleneck";

import Execution from "../models/executions.js";
import ComparisonRecord from "../models/comparison-records.js";

import { fetchProjectDatabases } from "../clients/database-api.js";
import { buildUatProdPairs } from "./build-pairs.js";
import { compareRecord } from "./compare-record.js";
import { finalizeExecution } from "./finalize-execution.js";

const limiter = new Bottleneck({
  maxConcurrent: 10,
  minTime: 100,
});

export async function processExecution(kafkaEvent) {
  const execution = await Execution.create({
    projectId: kafkaEvent.projectId,
    eventId: kafkaEvent.id,
    status: "running",
    approvalStatus: "unknown",
  });

  try {
    const databases = await fetchProjectDatabases(kafkaEvent.projectId);
    const pairs = buildUatProdPairs(databases);

    await Execution.updateOne(
      { _id: execution._id },
      {
        $set: {
          totalDatabases: databases.length,
          totalPairs: pairs.length,
        },
      }
    );

    await ComparisonRecord.insertMany(
      pairs.map((pair) => ({
        executionId: execution._id,
        projectId: kafkaEvent.projectId,

        source: {
          env: "UAT",
          databaseId: pair.uat.id,
          name: pair.uat.name,
        },

        target: {
          env: "PROD",
          databaseId: pair.prod.id,
          name: pair.prod.name,
        },

        status: "pending",
      }))
    );

    const records = await ComparisonRecord.find({
      executionId: execution._id,
      status: "pending",
    }).lean();

    await Promise.all(
      records.map((record) =>
        limiter.schedule(() => compareRecord(record))
      )
    );

    await finalizeExecution(execution._id);
  } catch (err) {
    await Execution.updateOne(
      { _id: execution._id },
      {
        $set: {
          status: "failed",
          approvalStatus: "unapproved",
          error: err.message,
          completedAt: new Date(),
        },
      }
    );
  }
}

