import ComparisonRecord from "../models/comparison-records.js";
import { fetchDatabaseConfig } from "../clients/database-api.js";
import { hashConfig } from "./hash-config.js";
import { diffConfigs } from "./diff-configs.js";

export async function compareRecord(record) {
  const claimResult = await ComparisonRecord.updateOne(
    {
      _id: record._id,
      status: "pending",
    },
    {
      $set: {
        status: "running",
        startedAt: new Date(),
        updatedAt: new Date(),
      },
    }
  );

  if (claimResult.modifiedCount === 0) {
    return;
  }

  try {
    const [uatConfig, prodConfig] = await Promise.all([
      fetchDatabaseConfig(record.source.databaseId),
      fetchDatabaseConfig(record.target.databaseId),
    ]);

    const sourceHash = hashConfig(uatConfig);
    const targetHash = hashConfig(prodConfig);

    if (sourceHash === targetHash) {
      await ComparisonRecord.updateOne(
        { _id: record._id },
        {
          $set: {
            status: "same",
            sourceHash,
            targetHash,
            diffCount: 0,
            diff: null,
            completedAt: new Date(),
            updatedAt: new Date(),
          },
        }
      );

      return;
    }

    const { diffCount, diff } = diffConfigs(uatConfig, prodConfig);

    await ComparisonRecord.updateOne(
      { _id: record._id },
      {
        $set: {
          status: "different",
          sourceHash,
          targetHash,
          diffCount,
          diff,
          completedAt: new Date(),
          updatedAt: new Date(),
        },
      }
    );
  } catch (err) {
    await ComparisonRecord.updateOne(
      { _id: record._id },
      {
        $set: {
          status: "failed",
          error: err.message,
          completedAt: new Date(),
          updatedAt: new Date(),
        },
      }
    );
  }
}

