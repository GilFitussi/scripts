import Execution from "../models/executions.js";
import ComparisonRecord from "../models/comparison-records.js";

export async function finalizeExecution(executionId) {
  const summary = await ComparisonRecord.aggregate([
    { $match: { executionId } },
    {
      $group: {
        _id: "$status",
        count: { $sum: 1 },
      },
    },
  ]);

  const counts = Object.fromEntries(
    summary.map((item) => [item._id, item.count])
  );

  const hasDifferences = (counts.different || 0) > 0;
  const hasFailures = (counts.failed || 0) > 0;

  await Execution.updateOne(
    { _id: executionId },
    {
      $set: {
        status: hasFailures ? "completed_with_errors" : "completed",
        approvalStatus:
          hasDifferences || hasFailures ? "unapproved" : "approved",
        completedAt: new Date(),
      },
    }
  );
}

