// file: services/diff-configs.js
// ========================================

import { create } from "jsondiffpatch";

const diffPatcher = create({
  arrays: {
    detectMove: false,
  },
});

export function diffConfigs(uatConfig, prodConfig) {
  const diff = diffPatcher.diff(uatConfig, prodConfig);

  if (!diff) {
    return {
      diffCount: 0,
      diff: null,
    };
  }

  return {
    diffCount: countDiffs(diff),
    diff,
  };
}

function countDiffs(node) {
  if (!node || typeof node !== "object") {
    return 0;
  }

  if (Array.isArray(node)) {
    return 1;
  }

  return Object.values(node).reduce(
    (count, value) => count + countDiffs(value),
    0
  );
}

