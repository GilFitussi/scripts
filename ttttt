export function buildUatProdPairs(databases) {
  const grouped = {};

  for (const db of databases) {
    const key = db.name;

    if (!grouped[key]) {
      grouped[key] = {};
    }

    grouped[key][db.environment] = db;
  }

  return Object.entries(grouped)
    .filter(([, envs]) => envs.UAT && envs.PROD)
    .map(([name, envs]) => ({
      name,
      uat: envs.UAT,
      prod: envs.PROD,
    }));
}

