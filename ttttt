import mongoose from "mongoose";

const ComparisonRecordSchema = new mongoose.Schema(
  {
    executionId: {
      type: mongoose.Schema.Types.ObjectId,
      ref: "Execution",
      required: true,
      index: true,
    },

    projectId: { type: String, required: true, index: true },

    source: {
      env: String,
      databaseId: String,
      name: String,
    },

    target: {
      env: String,
      databaseId: String,
      name: String,
    },

    status: {
      type: String,
      enum: ["pending", "running", "same", "different", "failed"],
      default: "pending",
      index: true,
    },

    sourceHash: { type: String, default: null },
    targetHash: { type: String, default: null },

    diffCount: { type: Number, default: null },
    diff: { type: Object, default: null },

    error: { type: String, default: null },

    startedAt: { type: Date, default: null },
    completedAt: { type: Date, default: null },
    createdAt: { type: Date, default: Date.now },
    updatedAt: { type: Date, default: Date.now },
